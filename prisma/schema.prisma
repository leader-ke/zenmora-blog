generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Category {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  heroLabel   String?
  posts       Post[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Post {
  id              String     @id @default(cuid())
  title           String
  slug            String     @unique
  excerpt         String
  content         String
  authorName      String?
  tags            String?
  metaTitle       String?
  metaDescription String?
  attachmentUrl   String?
  attachmentName  String?
  status          PostStatus @default(DRAFT)
  featured        Boolean    @default(false)
  latest          Boolean    @default(false)
  heroImage       String
  heroAlt         String
  likesCount      Int        @default(0)
  notifiedAt      DateTime?
  roomSort        Int        @default(0)
  publishedAt     DateTime?
  categoryId      String
  category        Category   @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  comments        Comment[]
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
}

model SiteContent {
  id                    Int      @id @default(1)
  siteTitle             String   @default("Zenmora Co.")
  siteTagline           String   @default("Creating calm, beautiful spaces")
  heroTitle             String   @default("Zenmora Co.")
  heroSubtitle          String   @default("Creating calm, beautiful spaces")
  heroCtaLabel          String   @default("Explore Ideas")
  heroCtaHref           String   @default("/blog")
  heroImage             String   @default("/images/hero-room.svg")
  heroImageAlt          String   @default("Soft neutral living room")
  trendingTitle         String   @default("Trending Now")
  trendingBody          String   @default("At Zenmora Co., we believe your home should feel as beautiful as it looks. We share modern, cozy, and budget-friendly ideas to help you create a space you truly love.")
  trendingCtaLabel      String   @default("Read More")
  trendingCtaHref       String   @default("/blog")
  trendingImage         String   @default("/images/trending-room.svg")
  newsletterTitle       String   @default("Join Zenmora Co.")
  newsletterBody        String   @default("Get weekly home inspiration and decor ideas.")
  newsletterPlaceholder String   @default("Enter your email")
  newsletterButtonLabel String   @default("Subscribe")
  newsletterSuccess     String   @default("Thanks for subscribing.")
  contactEyebrow        String   @default("Contact")
  contactTitle          String   @default("Collaborations, sponsorships, and reader questions")
  contactBody           String   @default("Use the form to reach the Zenmora Co. inbox. Messages land in the admin panel so editorial requests and partnership inquiries are not lost.")
  contactScopeTitle     String   @default("Response scope")
  contactScopeBody      String   @default("Brand collaborations, product features, styling consultations, reader questions, and press outreach.")
  contactFormEyebrow    String   @default("Send a message")
  contactFormTitle      String   @default("Contact Zenmora Co.")
  contactSuccess        String   @default("Your message has been received.")
  footerNote            String   @default("Calm interiors, thoughtful living.")
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model Subscriber {
  id                String           @id @default(cuid())
  email             String           @unique
  status            SubscriberStatus @default(SUBSCRIBED)
  unsubscribeToken  String           @unique @default(cuid())
  subscribedAt      DateTime         @default(now())
  unsubscribedAt    DateTime?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
}

model Comment {
  id        String   @id @default(cuid())
  name      String
  email     String
  content   String
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model ContactMessage {
  id         String               @id @default(cuid())
  name       String
  email      String
  subject    String
  message    String
  status     ContactMessageStatus @default(NEW)
  createdAt  DateTime             @default(now())
  updatedAt  DateTime             @updatedAt
}

model ShopItem {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  price     String
  href      String
  retailer  String?
  image     String
  imageAlt  String
  featured  Boolean  @default(false)
  active    Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum PostStatus {
  DRAFT
  PUBLISHED
}

enum SubscriberStatus {
  SUBSCRIBED
  UNSUBSCRIBED
}

enum ContactMessageStatus {
  NEW
  REVIEWED
}
